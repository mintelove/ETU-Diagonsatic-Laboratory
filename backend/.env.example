NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/ETU_Diagonstic_Labratory?retryWrites=true&w=majority
# Optional: copy the standard (non-SRV) connection string from MongoDB Atlas when SRV DNS is blocked.
# MONGODB_URI_FALLBACK=mongodb://<user>:<password>@<host1>:27017,<host2>:27017,<host3>:27017/ETU_Diagonstic_Labratory?tls=true&replicaSet=<replica-set>&authSource=admin&retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=8h
CLIENT_URL=http://localhost:5173
INITIAL_ADMIN_NAME=System Administrator
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=ChangeMeImmediately!2026
INITIAL_ADMIN_PHONE=+254700000000
